{
  "name": "site-draft-nextra",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "pnpm build:chapters && next dev",
    "build": "BASE_PATH=/ecma262/draft-nextra pnpm build:chapters && BASE_PATH=/ecma262/draft-nextra next build && pagefind --site out --output-subdir _pagefind",
    "start": "next start",
    "build:chapters": "node ../shared/scripts/build-chapters.mjs --input ../../ecma262/draft/spec.html --base-path \"${BASE_PATH:-}\"",
    "postinstall": "node ../shared/scripts/patch-nextra-theme.mjs"
  },
  "dependencies": {
    "shared": "workspace:*",
    "next": "^16.2.6",
    "nextra": "^4.6.1",
    "nextra-theme-docs": "^4.6.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "pagefind": "^1.5.2"
  }
}
