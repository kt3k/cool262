{
  "name": "site-draft",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "pnpm build:chapters && next dev",
    "build": "BASE_PATH=/cool262/draft pnpm build:chapters && BASE_PATH=/cool262/draft next build",
    "start": "next start",
    "build:chapters": "node ../shared/scripts/build-chapters.mjs --input ../../ecma262/draft/spec.html --base-path \"${BASE_PATH:-}\"",
    "postinstall": "node ../shared/scripts/patch-nextra-theme.mjs"
  },
  "dependencies": {
    "next": "^16.2.6",
    "nextra": "^4.6.1",
    "nextra-theme-docs": "^4.6.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  }
}
