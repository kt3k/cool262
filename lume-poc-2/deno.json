{
  "imports": {
    "lume/": "https://deno.land/x/lume@v3.0.5/",
    "lume/jsx-runtime": "https://deno.land/x/ssx@v0.1.10/jsx-runtime.ts"
  },
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "lume"
  },
  "tasks": {
    "build": "deno run -A _config.ts",
    "pagefind": "deno run -A npm:pagefind --site _site --output-subdir pagefind"
  }
}
